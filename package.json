  "private": true,
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=24.15.0 <25",
    "bun": ">=1.3.14 <2"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "NODE_ENV=production vite build",
    "start": "HOST=0.0.0.0 PORT=4000 node .output/server/index.mjs",
    "preview": "bun run start",
    "prepare": "husky",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint:oxc": "oxlint .",
    "lint:eslint": "eslint .",
    "lint": "bun run lint:oxc && bun run lint:eslint",
    "api:generate": "bun run scripts/codegen/generate-api.ts",
    "api:regen": "bun run scripts/codegen/generate-api.ts --refresh",
    "api:check": "bun run scripts/codegen/generate-api.ts --check",
    "proto:generate": "bun run scripts/codegen/generate-live-protocol.ts",
    "proto:check": "bun run scripts/codegen/generate-live-protocol.ts --check && buf lint proto",
    "typecheck": "tsc --noEmit",
    "check": "bun run format:check && bun run api:check && bun run proto:check && bun run typecheck && bun run lint && bun test && bun run build"
  },
  "type": "module"
}
